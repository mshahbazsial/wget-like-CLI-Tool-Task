"""
wget-like CLI tool - Stage 2: Output File Naming
Added --output/-o option for custom filename
"""

import urllib.request
import urllib.error
import sys
import os
import argparse

def download_file(url, output_filename=None):
    """
    Download file from given URL with optional custom filename
    """
    try:
        # Determine filename
        if output_filename:
            filename = output_filename
        else:
            filename = os.path.basename(url)
            if not filename:
                filename = 'downloaded_file'
        
        print(f"Downloading: {url}")
        print(f"Saving as: {filename}")
        
        # Download the file
        urllib.request.urlretrieve(url, filename)
        
        print(f"Download completed: {filename}")
        return True
        
    except urllib.error.URLError as e:
        print(f"Error downloading file: {e}", file=sys.stderr)
        return False
    except Exception as e:
        print(f"Unexpected error: {e}", file=sys.stderr)
        return False

def main():
    """
    Main function with argument parsing
    """
    parser = argparse.ArgumentParser(
        description='Download files from the internet (wget-like tool)',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='Examples:\n  %(prog)s https://example.com/file.txt\n  %(prog)s https://example.com/file.txt -o custom_name.txt'
    )
    
    parser.add_argument(
        'url',
        help='URL of the file to download'
    )
    
    parser.add_argument(
        '-o', '--output',
        help='Save file with specified name'
    )
    
    args = parser.parse_args()
    
    # Validate URL
    if not args.url.startswith(('http://', 'https://')):
        print("Error: URL must start with http:// or https://", file=sys.stderr)
        sys.exit(1)
    
    success = download_file(args.url, args.output)
    sys.exit(0 if success else 1)

if __name__ == "__main__":
    main()
